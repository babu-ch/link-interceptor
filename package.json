{
  "name": "vue-link-interceptor",
  "version": "0.1.0",
  "description": "Vue 3 plugin to intercept all <a> tag clicks in your SPA — handle internal routing and external link modifications with ease.",
  "keywords": [
    "anchor",
    "interceptor",
    "link",
    "plugin",
    "router",
    "spa",
    "vue",
    "vue3"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/and and/vue-link-interceptor"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "pnpm -C playground dev",
    "build": "vp pack",
    "build:playground": "pnpm -C playground build",
    "preview:playground": "pnpm -C playground preview",
    "test": "vp test run",
    "test:watch": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check"
  },
  "devDependencies": {
    "jsdom": "^29.0.1",
    "typescript": "^5.8.2",
    "vite-plus": "^0.1.14",
    "vue": "^3.5.31"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  }
}
