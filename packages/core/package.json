{
  "name": "link-interceptor",
  "version": "0.1.0",
  "description": "Intercept all <a> tag clicks in your SPA — framework-agnostic core for handling internal and external link navigation.",
  "keywords": [
    "anchor",
    "interceptor",
    "link",
    "router",
    "spa",
    "click",
    "capture"
  ],
  "author": "babu-ch",
  "license": "MIT",
  "homepage": "https://github.com/babu-ch/vue-link-interceptor/tree/main/packages/core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babu-ch/vue-link-interceptor.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/babu-ch/vue-link-interceptor/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run",
    "lint": "vp lint"
  },
  "devDependencies": {
    "jsdom": "^29.0.1",
    "typescript": "^5.8.2",
    "vite-plus": "^0.1.14"
  }
}
