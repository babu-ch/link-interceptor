{
  "name": "react-link-interceptor",
  "version": "0.1.0",
  "description": "React hook to intercept all <a> tag clicks in your SPA — handle internal routing and external link modifications with ease.",
  "keywords": [
    "anchor",
    "interceptor",
    "link",
    "hook",
    "router",
    "spa",
    "react"
  ],
  "author": "babu-ch",
  "license": "MIT",
  "homepage": "https://github.com/babu-ch/link-interceptor/tree/main/packages/react",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babu-ch/link-interceptor.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/babu-ch/link-interceptor/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run",
    "lint": "vp lint"
  },
  "dependencies": {
    "link-interceptor": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.2",
    "vite-plus": "^0.1.14"
  }
}
